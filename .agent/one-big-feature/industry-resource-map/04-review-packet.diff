+from __future__ import annotations
+
+import json
+import os
+import subprocess
+import sys
+import tempfile
+import unittest
+import unittest.mock
+from datetime import datetime, timedelta, timezone
+from pathlib import Path
+
+
+ROOT = Path(__file__).resolve().parent.parent
+if str(ROOT) not in sys.path:
+    sys.path.insert(0, str(ROOT))
+
+from scripts import registry_ref as MODULE
+
+
+class RegistryRefTests(unittest.TestCase):
+    def write_registry(self, root: str, payload: dict[str, object]) -> Path:
+        path = Path(root) / "registry" / "aec.json"
+        path.parent.mkdir(parents=True, exist_ok=True)
+        path.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")
+        return path
+
+    def make_registry(
+        self,
+        *,
+        last_checked: str | None,
+        updated_at: str | None,
+    ) -> dict[str, object]:
+        return {
+            "vertical": "aec",
+            "notebook_id": "nb-aec",
+            "framework_doc": "/tmp/aec-indicator-framework.md",
+            "updated_at": updated_at,
+            "sources": [
+                {
+                    "id": "src_aec",
+                    "url": "https://example.com/aec",
+                    "last_checked": last_checked,
+                }
+            ],
+        }
+
+    def test_read_registry_ref_readonly(self) -> None:
+        with tempfile.TemporaryDirectory() as tmp:
+            path = self.write_registry(
+                tmp,
+                self.make_registry(
+                    last_checked="2026-07-18T10:00:00Z",
+                    updated_at="2026-07-18T10:00:00Z",
+                ),
+            )
+            before_bytes = path.read_bytes()
+            before_mtime = path.stat().st_mtime_ns
+            with unittest.mock.patch.dict(os.environ, {"PULSE_STATE_DIR": tmp}, clear=False):
+                ref = MODULE.read_registry_ref("aec")
+            self.assertEqual(path.read_bytes(), before_bytes)
+            self.assertEqual(path.stat().st_mtime_ns, before_mtime)
+            self.assertEqual(ref["registry_path"], str(path.resolve()))
+            self.assertEqual(ref["notebook_id"], "nb-aec")
+            self.assertEqual(ref["source_count"], 1)
+
+    def test_freshness_fresh(self) -> None:
+        now = datetime(2026, 7, 18, 18, 0, tzinfo=timezone.utc)
+        recent = (now - timedelta(hours=1)).strftime("%Y-%m-%dT%H:%M:%SZ")
+        with tempfile.TemporaryDirectory() as tmp:
+            self.write_registry(tmp, self.make_registry(last_checked=recent, updated_at=recent))
+            with unittest.mock.patch.dict(os.environ, {"PULSE_STATE_DIR": tmp}, clear=False):
+                freshness = MODULE.compute_freshness("aec", now=now)
+            self.assertFalse(freshness["is_stale"])
+            self.assertLess(float(freshness["age_hours"]), 2.0)
+
+    def test_freshness_stale_by_last_checked(self) -> None:
+        now = datetime(2026, 7, 18, 18, 0, tzinfo=timezone.utc)
+        with tempfile.TemporaryDirectory() as tmp:
+            self.write_registry(tmp, self.make_registry(last_checked="2026-01-01T00:00:00Z", updated_at="2026-07-01T00:00:00Z"))
+            with unittest.mock.patch.dict(os.environ, {"PULSE_STATE_DIR": tmp}, clear=False):
+                freshness = MODULE.compute_freshness("aec", now=now)
+            self.assertTrue(freshness["is_stale"])
+
+    def test_freshness_updated_at_fallback(self) -> None:
+        now = datetime(2026, 7, 18, 18, 0, tzinfo=timezone.utc)
+        with tempfile.TemporaryDirectory() as tmp:
+            recent = (now - timedelta(hours=1)).strftime("%Y-%m-%dT%H:%M:%SZ")
+            self.write_registry(tmp, self.make_registry(last_checked=None, updated_at=recent))
+            with unittest.mock.patch.dict(os.environ, {"PULSE_STATE_DIR": tmp}, clear=False):
+                fresh = MODULE.compute_freshness("aec", now=now)
+            self.assertFalse(fresh["is_stale"])
+
+        with tempfile.TemporaryDirectory() as tmp:
+            self.write_registry(tmp, self.make_registry(last_checked=None, updated_at="2026-01-01T00:00:00Z"))
+            with unittest.mock.patch.dict(os.environ, {"PULSE_STATE_DIR": tmp}, clear=False):
+                stale = MODULE.compute_freshness("aec", now=now)
+            self.assertTrue(stale["is_stale"])
+
+    def test_freshness_no_signal_is_stale(self) -> None:
+        with tempfile.TemporaryDirectory() as tmp:
+            self.write_registry(tmp, self.make_registry(last_checked=None, updated_at=None))
+            with unittest.mock.patch.dict(os.environ, {"PULSE_STATE_DIR": tmp}, clear=False):
+                freshness = MODULE.compute_freshness("aec")
+            self.assertTrue(freshness["is_stale"])
+            self.assertIsNone(freshness["age_hours"])
+
+    def test_build_delta_command_exact(self) -> None:
+        command = MODULE.build_delta_command("aec")
+        self.assertEqual(command, "python3 .claude/skills/research-pulse/scripts/delta_check.py --vertical aec")
+        with tempfile.TemporaryDirectory() as tmp:
+            self.write_registry(tmp, self.make_registry(last_checked=None, updated_at=None))
+            with unittest.mock.patch.dict(os.environ, {"PULSE_STATE_DIR": tmp}, clear=False):
+                freshness = MODULE.compute_freshness("aec")
+            self.assertEqual(freshness["delta_refresh_command"], command)
+            self.assertEqual(freshness["delta_cron_name"], "research-pulse-delta")
+
+    def test_request_delta_refresh_announce_only(self) -> None:
+        with tempfile.TemporaryDirectory() as tmp:
+            with unittest.mock.patch.object(MODULE.subprocess, "run") as mocked:
+                result = MODULE.request_delta_refresh("aec", agent_home=tmp, run=False)
+            mocked.assert_not_called()
+            self.assertTrue(result["requested"])
+            self.assertFalse(result["ran"])
+
+    def test_request_delta_refresh_runs(self) -> None:
+        with tempfile.TemporaryDirectory() as tmp:
+            script = Path(tmp) / MODULE.DELTA_SCRIPT_REL
+            script.parent.mkdir(parents=True, exist_ok=True)
+            script.write_text("#!/usr/bin/env python3\n", encoding="utf-8")
+            completed = subprocess.CompletedProcess(
+                [sys.executable, str(script), "--vertical", "aec"],
+                0,
+                stdout=json.dumps({"updated": 1}),
+                stderr="",
+            )
+            with unittest.mock.patch.object(MODULE.subprocess, "run", return_value=completed) as mocked:
+                result = MODULE.request_delta_refresh("aec", agent_home=tmp, run=True)
+            mocked.assert_called_once()
+            args, kwargs = mocked.call_args
+            self.assertEqual(args[0], [sys.executable, str(script.resolve()), "--vertical", "aec"])
+            self.assertEqual(kwargs["cwd"], Path(tmp).resolve())
+            self.assertEqual(result["summary"], {"updated": 1})
+
+    def test_request_delta_refresh_script_missing(self) -> None:
+        with tempfile.TemporaryDirectory() as tmp:
+            result = MODULE.request_delta_refresh("aec", agent_home=tmp, run=True)
+            self.assertFalse(result["ran"])
+            self.assertEqual(result["reason"], "delta_script_missing")
+
+    def test_refresh_if_stale_announced_when_run_false(self) -> None:
+        with tempfile.TemporaryDirectory() as tmp:
+            self.write_registry(tmp, self.make_registry(last_checked="2026-01-01T00:00:00Z", updated_at="2026-01-01T00:00:00Z"))
+            with unittest.mock.patch.dict(os.environ, {"PULSE_STATE_DIR": tmp}, clear=False):
+                result = MODULE.refresh_if_stale("aec", run=False)
+            self.assertEqual(result["action"], "announced")
+            self.assertTrue(result["freshness"]["delta_refresh_requested"])
+
+    def test_refresh_if_stale_refreshed_when_run_true(self) -> None:
+        stale = {
+            "checked_at": "2026-07-18T18:00:00Z",
+            "registry_updated_at": "2026-01-01T00:00:00Z",
+            "most_recent_last_checked": "2026-01-01T00:00:00Z",
+            "age_hours": 100.0,
+            "stale_threshold_hours": 18.0,
+            "is_stale": True,
+            "delta_refresh_requested": False,
+            "delta_refresh_command": MODULE.build_delta_command("aec"),
+            "delta_cron_name": MODULE.DELTA_CRON_NAME,
+        }
+        fresh = dict(stale, is_stale=False, age_hours=1.0)
+        request = {
+            "requested": True,
+            "ran": True,
+            "returncode": 0,
+            "command": MODULE.build_delta_command("aec"),
+            "summary": {"updated": 1},
+            "cron_name": MODULE.DELTA_CRON_NAME,
+        }
+        with unittest.mock.patch.object(MODULE, "compute_freshness", side_effect=[stale, fresh]):
+            with unittest.mock.patch.object(MODULE, "request_delta_refresh", return_value=request):
+                result = MODULE.refresh_if_stale("aec", run=True)
+        self.assertEqual(result["action"], "refreshed")
+        self.assertTrue(result["freshness"]["delta_refresh_requested"])
+
+
+if __name__ == "__main__":
+    unittest.main()
