+from __future__ import annotations
+
+import argparse
+import json
+import os
+import subprocess
+import sys
+from datetime import datetime, timezone
+from pathlib import Path
+
+
+RESEARCH_PULSE_STATE_DIR = (
+    "/Users/joshweiss/code/cortextos/orgs/clearworksai/agents/muse/state/research-pulse"
+)
+MUSE_AGENT_HOME = (
+    "/Users/joshweiss/code/cortextos/orgs/clearworksai/agents/muse"
+)
+DELTA_SCRIPT_REL = ".claude/skills/research-pulse/scripts/delta_check.py"
+DELTA_CRON_NAME = "research-pulse-delta"
+STALE_THRESHOLD_HOURS = 18.0
+
+
+def registry_path(vertical: str) -> Path:
+    state_root = Path(os.environ.get("PULSE_STATE_DIR", RESEARCH_PULSE_STATE_DIR)).expanduser()
+    return state_root / "registry" / f"{vertical}.json"
+
+
+def _parse_iso8601(value: object) -> datetime | None:
+    if not isinstance(value, str) or not value:
+        return None
+    try:
+        return datetime.strptime(value, "%Y-%m-%dT%H:%M:%SZ").replace(tzinfo=timezone.utc)
+    except ValueError:
+        return None
+
+
+def utc_now() -> datetime:
+    return datetime.now(timezone.utc)
+
+
+def utc_now_iso(now: datetime | None = None) -> str:
+    return (now or utc_now()).strftime("%Y-%m-%dT%H:%M:%SZ")
+
+
+def _load_registry(vertical: str) -> dict[str, object]:
+    path = registry_path(vertical)
+    if not path.exists():
+        raise FileNotFoundError(f"registry not found: {path}")
+    with path.open(encoding="utf-8") as handle:
+        registry = json.load(handle)
+    if not isinstance(registry, dict):
+        raise ValueError("registry must be an object")
+    if not isinstance(registry.get("vertical"), str):
+        raise ValueError("registry missing vertical")
+    if not isinstance(registry.get("sources"), list):
+        raise ValueError("registry missing sources list")
+    return registry
+
+
+def read_registry_ref(vertical: str) -> dict[str, object]:
+    registry = _load_registry(vertical)
+    return {
+        "registry_path": str(registry_path(vertical).resolve()),
+        "notebook_id": registry.get("notebook_id"),
+        "framework_doc": registry.get("framework_doc"),
+        "source_count": len(registry.get("sources", [])),
+        "registry_updated_at": registry.get("updated_at"),
+    }
+
+
+def build_delta_command(vertical: str) -> str:
+    return f"python3 {DELTA_SCRIPT_REL} --vertical {vertical}"
+
+
+def compute_freshness(
+    vertical: str,
+    *,
+    stale_hours: float = STALE_THRESHOLD_HOURS,
+    now: datetime | None = None,
+) -> dict[str, object]:
+    registry = _load_registry(vertical)
+    effective_now = now or utc_now()
+    sources = registry.get("sources", [])
+    most_recent: datetime | None = None
+    if isinstance(sources, list):
+        for source in sources:
+            if not isinstance(source, dict):
+                continue
+            checked = _parse_iso8601(source.get("last_checked"))
+            if checked and (most_recent is None or checked > most_recent):
+                most_recent = checked
+    if most_recent is None:
+        most_recent = _parse_iso8601(registry.get("updated_at"))
+
+    age_hours: float | None = None
+    is_stale = True
+    most_recent_iso: str | None = None
+    if most_recent is not None:
+        age_hours = (effective_now - most_recent).total_seconds() / 3600
+        is_stale = age_hours > stale_hours
+        most_recent_iso = utc_now_iso(most_recent)
+
+    return {
+        "checked_at": utc_now_iso(effective_now),
+        "registry_updated_at": registry.get("updated_at"),
+        "most_recent_last_checked": most_recent_iso,
+        "age_hours": round(age_hours, 1) if age_hours is not None else None,
+        "stale_threshold_hours": stale_hours,
+        "is_stale": is_stale,
+        "delta_refresh_requested": False,
+        "delta_refresh_command": build_delta_command(vertical),
+        "delta_cron_name": DELTA_CRON_NAME,
+    }
+
+
+def request_delta_refresh(
+    vertical: str,
+    agent_home: str | Path | None = None,
+    run: bool = False,
+) -> dict[str, object]:
+    agent_home_path = Path(agent_home or MUSE_AGENT_HOME).expanduser().resolve()
+    script = agent_home_path / DELTA_SCRIPT_REL
+    command = build_delta_command(vertical)
+    if not run:
+        return {
+            "requested": True,
+            "ran": False,
+            "command": command,
+            "cron_name": DELTA_CRON_NAME,
+            "script_path": str(script),
+            "reason": "announce-only",
+        }
+    if not script.exists():
+        return {
+            "requested": True,
+            "ran": False,
+            "command": command,
+            "cron_name": DELTA_CRON_NAME,
+            "script_path": str(script),
+            "reason": "delta_script_missing",
+        }
+
+    result = subprocess.run(
+        [sys.executable, str(script), "--vertical", vertical],
+        cwd=agent_home_path,
+        capture_output=True,
+        text=True,
+        timeout=600,
+    )
+    summary: object | None = None
+    stdout = (result.stdout or "").strip()
+    if stdout:
+        try:
+            summary = json.loads(stdout)
+        except json.JSONDecodeError:
+            summary = None
+    return {
+        "requested": True,
+        "ran": True,
+        "returncode": result.returncode,
+        "command": command,
+        "summary": summary,
+        "cron_name": DELTA_CRON_NAME,
+        "script_path": str(script),
+    }
+
+
+def refresh_if_stale(
+    vertical: str,
+    *,
+    stale_hours: float = STALE_THRESHOLD_HOURS,
+    run: bool = True,
+    agent_home: str | Path | None = None,
+    now: datetime | None = None,
+) -> dict[str, object]:
+    freshness = compute_freshness(vertical, stale_hours=stale_hours, now=now)
+    if not freshness["is_stale"]:
+        return {"freshness": freshness, "action": "none"}
+
+    request = request_delta_refresh(vertical, agent_home=agent_home, run=run)
+    freshness["delta_refresh_requested"] = True
+    if request.get("ran") and request.get("returncode") == 0:
+        refreshed = compute_freshness(vertical, stale_hours=stale_hours, now=now)
+        refreshed["delta_refresh_requested"] = True
+        return {"freshness": refreshed, "action": "refreshed", "request": request}
+    return {"freshness": freshness, "action": "announced", "request": request}
+
+
+def main(argv: list[str] | None = None) -> int:
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--vertical", required=True)
+    parser.add_argument("--stale-hours", type=float, default=STALE_THRESHOLD_HOURS)
+    parser.add_argument("--agent-home")
+    parser.add_argument("--check-only", action="store_true")
+    parser.add_argument("--no-run", action="store_true")
+    parser.add_argument("--json", action="store_true")
+    args = parser.parse_args(argv)
+
+    try:
+        if args.check_only:
+            payload = compute_freshness(args.vertical, stale_hours=args.stale_hours)
+        else:
+            payload = refresh_if_stale(
+                args.vertical,
+                stale_hours=args.stale_hours,
+                run=not args.no_run,
+                agent_home=args.agent_home,
+            )
+    except (FileNotFoundError, ValueError) as exc:  # pragma: no cover - CLI guard
+        print(str(exc), file=sys.stderr)
+        return 1
+
+    print(json.dumps(payload))
+    return 0
+
+
+if __name__ == "__main__":  # pragma: no cover - CLI entrypoint
+    raise SystemExit(main())
