+from __future__ import annotations
+
+import contextlib
+import io
+import json
+import sys
+import tempfile
+import unittest
+from pathlib import Path
+
+
+ROOT = Path(__file__).resolve().parent.parent
+FIXTURES = Path(__file__).resolve().parent / "fixtures"
+if str(ROOT) not in sys.path:
+    sys.path.insert(0, str(ROOT))
+
+from scripts import discover_internal as MODULE
+
+
+class DiscoverInternalTests(unittest.TestCase):
+    def setUp(self) -> None:
+        self.roots_json = FIXTURES / "roots.json"
+        self.aec_terms = MODULE.build_terms(
+            "aec",
+            "AEC",
+            [],
+            ["architecture", "engineering", "construction", "aec", "building", "design", "firm"],
+        )
+
+    def discover(self, terms: list[str]) -> list[dict[str, object]]:
+        roots = MODULE._load_roots(str(self.roots_json))
+        return MODULE.discover(roots, terms)
+
+    def test_scoring_ranks_on_topic_above_off_topic(self) -> None:
+        discovered = self.discover(self.aec_terms)
+        by_name = {Path(item["path"]).name: item for item in discovered}
+        self.assertGreater(int(by_name["alloi-ai-operations-audit.md"]["score"]), int(by_name["ai-trends-generic.md"]["score"]))
+        self.assertIn("aec", by_name["alloi-ai-operations-audit.md"]["matched_terms"])
+
+    def test_tiering_high_ambiguous_drop(self) -> None:
+        discovered = self.discover(self.aec_terms)
+        names = {Path(item["path"]).name: item["tier"] for item in discovered}
+        self.assertEqual(names["alloi-ai-operations-audit.md"], "high")
+        self.assertEqual(names["ai-trends-generic.md"], "ambiguous")
+        self.assertNotIn("nonprofit-donor-audit.md", names)
+
+    def test_ambiguous_not_auto_included(self) -> None:
+        with tempfile.TemporaryDirectory() as tmp:
+            out = Path(tmp) / "candidates.json"
+            with contextlib.redirect_stdout(io.StringIO()):
+                rc = MODULE.main([
+                    "--vertical", "aec",
+                    "--display-name", "AEC",
+                    "--synonym", "architecture",
+                    "--synonym", "engineering",
+                    "--synonym", "construction",
+                    "--synonym", "aec",
+                    "--synonym", "building",
+                    "--synonym", "design",
+                    "--synonym", "firm",
+                    "--roots-json", str(self.roots_json),
+                    "--out", str(out),
+                ])
+            self.assertEqual(rc, 0)
+            payload = json.loads(out.read_text(encoding="utf-8"))
+        ambiguous_names = {Path(item["path"]).name for item in payload["ambiguous"]}
+        high_names = {Path(item["path"]).name for item in payload["high"]}
+        self.assertIn("ai-trends-generic.md", ambiguous_names)
+        self.assertNotIn("ai-trends-generic.md", high_names)
+        for bucket in ("high", "ambiguous"):
+            for entry in payload[bucket]:
+                self.assertNotIn("confirmed", entry)
+
+    def test_category_by_root(self) -> None:
+        discovered = self.discover(self.aec_terms)
+        mapping = {Path(item["path"]).name: item["category"] for item in discovered}
+        self.assertEqual(mapping["alloi-ai-operations-audit.md"], "client_audits")
+        self.assertEqual(mapping["marketing-intelligence-v3.md"], "positioning_docs")
+        self.assertEqual(mapping["aec-indicator-framework.md"], "research_docs")
+        self.assertEqual(mapping["2026-07-16-aec-firm-notes.md"], "memory_refs")
+
+    def test_version_parse(self) -> None:
+        discovered = self.discover(self.aec_terms)
+        mapping = {Path(item["path"]).name: item for item in discovered}
+        self.assertEqual(mapping["marketing-intelligence-v3.md"]["version"], 3)
+        self.assertIsNone(mapping["aec-indicator-framework.md"]["version"])
+
+    def test_no_hardcoded_client_paths(self) -> None:
+        source = (ROOT / "scripts" / "discover_internal.py").read_text(encoding="utf-8").lower()
+        for needle in ("alloi", "marcos", "msia", "ocg", "marketing-intelligence-v3"):
+            self.assertNotIn(needle, source)
+
+    def test_second_vertical_same_code(self) -> None:
+        terms = MODULE.build_terms(
+            "nonprofit",
+            "Nonprofit",
+            [],
+            ["donor", "grant", "fundraising", "501c3"],
+        )
+        discovered = self.discover(terms)
+        top = max(discovered, key=lambda item: int(item["score"]))
+        self.assertEqual(Path(top["path"]).name, "nonprofit-donor-audit.md")
+
+
+if __name__ == "__main__":
+    unittest.main()
