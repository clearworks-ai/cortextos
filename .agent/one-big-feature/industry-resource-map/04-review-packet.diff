+from __future__ import annotations
+
+import argparse
+import json
+import os
+import re
+import sys
+from pathlib import Path
+
+
+HOME = Path(os.path.expanduser("~"))
+
+KNOWN_ROOTS = [
+    {"path": HOME / "code/knowledge-sync/raw/areas/clearworks", "category": "client_audits", "recursive": False},
+    {"path": HOME / "code/knowledge-sync/raw/areas/clearworks/research", "category": "research_docs", "recursive": False},
+    {"path": HOME / "code/knowledge-sync/raw/areas/clearworks/growth", "category": "positioning_docs", "recursive": False},
+    {"path": HOME / "code/knowledge-sync/wiki/projects", "category": "client_audits", "recursive": False},
+    {"path": HOME / "code/knowledge-sync/wiki/intelligence", "category": "positioning_docs", "recursive": False},
+    {"path": HOME / "code/cortextos/orgs/clearworksai/agents/muse/memory", "category": "memory_refs", "recursive": False},
+]
+
+CANDIDATE_EXTS = (".md", ".pdf")
+HEAD_LINES = 40
+FILENAME_WEIGHT = 3
+BODY_WEIGHT = 1
+HIGH_THRESHOLD = 4
+LOW_THRESHOLD = 2
+
+_TOKEN_RE = re.compile(r"[a-z0-9]+")
+_VERSION_RE = re.compile(r"(?:^|[-_])v(\d+)(?:$|[-_])")
+
+
+def slugify(name: str) -> str:
+    slug = "-".join(_TOKEN_RE.findall((name or "").lower())).strip("-")
+    if not slug:
+        raise ValueError("slugify() produced an empty slug")
+    return slug
+
+
+def utc_now_iso() -> str:
+    from datetime import datetime, timezone
+
+    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
+
+
+def build_terms(
+    vertical: str,
+    display_name: str,
+    topic_vocab_extra: list[str],
+    synonyms: list[str],
+) -> list[str]:
+    seen: set[str] = set()
+    ordered: list[str] = []
+    raw_terms = [vertical, display_name, *topic_vocab_extra, *synonyms]
+    for raw in raw_terms:
+        for token in _TOKEN_RE.findall((raw or "").lower()):
+            if len(token) < 3 or token in seen:
+                continue
+            seen.add(token)
+            ordered.append(token)
+    return ordered
+
+
+def _read_head_text(path: Path) -> str:
+    try:
+        with path.open(encoding="utf-8", errors="ignore") as handle:
+            lines = []
+            for index, line in enumerate(handle):
+                lines.append(line)
+                if index + 1 >= HEAD_LINES:
+                    break
+        return "".join(lines).lower()
+    except OSError:
+        return ""
+
+
+def score_file(path: Path, terms: list[str]) -> tuple[int, list[str]]:
+    filename = path.stem.lower()
+    body = _read_head_text(path)
+    score = 0
+    matched_terms: list[str] = []
+    for term in terms:
+        if term in filename:
+            score += FILENAME_WEIGHT
+            matched_terms.append(term)
+        elif term in body:
+            score += BODY_WEIGHT
+            matched_terms.append(term)
+    return score, matched_terms
+
+
+def tier(score: int) -> str:
+    if score >= HIGH_THRESHOLD:
+        return "high"
+    if score >= LOW_THRESHOLD:
+        return "ambiguous"
+    return "drop"
+
+
+def _human_title(path: Path) -> str:
+    return re.sub(r"[-_]+", " ", path.stem).strip().title()
+
+
+def _load_roots(path: str | None) -> list[dict[str, object]]:
+    if path is None:
+        return [
+            {"path": str(root["path"]), "category": root["category"], "recursive": root["recursive"]}
+            for root in KNOWN_ROOTS
+        ]
+    roots_path = Path(path).expanduser().resolve()
+    with roots_path.open(encoding="utf-8") as handle:
+        payload = json.load(handle)
+    if not isinstance(payload, list):
+        raise ValueError("roots-json must contain a list")
+    resolved: list[dict[str, object]] = []
+    for index, root in enumerate(payload):
+        if not isinstance(root, dict):
+            raise ValueError(f"roots-json entry {index} must be an object")
+        raw_path = root.get("path")
+        category = root.get("category")
+        recursive = root.get("recursive", False)
+        if not isinstance(raw_path, str) or not isinstance(category, str) or not isinstance(recursive, bool):
+            raise ValueError(f"roots-json entry {index} missing path/category/recursive")
+        path_obj = Path(raw_path)
+        if not path_obj.is_absolute():
+            path_obj = (roots_path.parent / path_obj).resolve()
+        resolved.append({"path": str(path_obj), "category": category, "recursive": recursive})
+    return resolved
+
+
+def _should_skip_dir(path: Path) -> bool:
+    name = path.name
+    return (
+        name.startswith(".")
+        or name == "__pycache__"
+        or name.startswith("_quarantine")
+        or name == ".trash"
+    )
+
+
+def _iter_candidates(root_path: Path, recursive: bool) -> list[Path]:
+    out: list[Path] = []
+    if not root_path.exists():
+        return out
+    if recursive:
+        for current_root, dirnames, filenames in os.walk(root_path):
+            dir_path = Path(current_root)
+            dirnames[:] = [name for name in dirnames if not _should_skip_dir(dir_path / name)]
+            for name in filenames:
+                if name.startswith("."):
+                    continue
+                candidate = dir_path / name
+                if candidate.suffix.lower() in CANDIDATE_EXTS:
+                    out.append(candidate.resolve())
+    else:
+        for candidate in sorted(root_path.iterdir(), key=lambda item: item.name):
+            if candidate.is_dir() or candidate.name.startswith("."):
+                continue
+            if candidate.suffix.lower() in CANDIDATE_EXTS:
+                out.append(candidate.resolve())
+    return out
+
+
+def discover(roots: list[dict[str, object]], terms: list[str]) -> list[dict[str, object]]:
+    candidates: list[dict[str, object]] = []
+    for root in roots:
+        root_path = Path(str(root["path"])).expanduser().resolve()
+        category = str(root["category"])
+        recursive = bool(root.get("recursive", False))
+        for candidate in _iter_candidates(root_path, recursive):
+            score, matched_terms = score_file(candidate, terms)
+            confidence = tier(score)
+            if confidence == "drop":
+                continue
+            version_match = _VERSION_RE.search(candidate.stem.lower())
+            candidates.append({
+                "category": category,
+                "title": _human_title(candidate),
+                "path": str(candidate),
+                "score": score,
+                "matched_terms": matched_terms,
+                "tier": confidence,
+                "version": int(version_match.group(1)) if version_match else None,
+            })
+    return sorted(candidates, key=lambda item: (str(item["category"]), -int(item["score"]), str(item["path"])))
+
+
+def main(argv: list[str] | None = None) -> int:
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--vertical", required=True)
+    parser.add_argument("--display-name", required=True)
+    parser.add_argument("--synonym", action="append", default=[])
+    parser.add_argument("--topic", action="append", default=[])
+    parser.add_argument("--roots-json")
+    parser.add_argument("--out", required=True)
+    args = parser.parse_args(argv)
+
+    try:
+        roots = _load_roots(args.roots_json)
+    except (OSError, ValueError, json.JSONDecodeError) as exc:  # pragma: no cover - CLI guard
+        print(str(exc), file=sys.stderr)
+        return 1
+
+    missing_roots = []
+    usable_roots: list[dict[str, object]] = []
+    for root in roots:
+        path = Path(str(root["path"])).expanduser().resolve()
+        if path.exists():
+            usable_roots.append(root)
+        else:
+            missing_roots.append(path)
+    for path in missing_roots:  # pragma: no cover - CLI note
+        print(f"skipping missing root: {path}", file=sys.stderr)
+
+    terms = build_terms(args.vertical, args.display_name, list(args.topic), list(args.synonym))
+    discovered = discover(usable_roots, terms)
+    payload = {
+        "vertical": args.vertical,
+        "generated_at": utc_now_iso(),
+        "terms": terms,
+        "high": [item for item in discovered if item["tier"] == "high"],
+        "ambiguous": [item for item in discovered if item["tier"] == "ambiguous"],
+    }
+
+    out_path = Path(args.out).expanduser().resolve()
+    out_path.parent.mkdir(parents=True, exist_ok=True)
+    with out_path.open("w", encoding="utf-8") as handle:
+        json.dump(payload, handle, indent=2)
+        handle.write("\n")
+    print(out_path)
+    return 0
+
+
+if __name__ == "__main__":  # pragma: no cover - CLI entrypoint
+    raise SystemExit(main())
