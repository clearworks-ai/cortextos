+++ b/Users/joshweiss/code/cortextos/orgs/clearworksai/agents/muse/.claude/skills/industry-resource-map/scripts/resource_map.py
@@ -0,0 +1,623 @@
+from __future__ import annotations
+
+import argparse
+import json
+import os
+import re
+import tempfile
+from datetime import datetime, timezone
+from pathlib import Path
+
+
+SCHEMA_VERSION = 1
+
+DEFAULT_STATE_DIR = (
+    "/Users/joshweiss/code/cortextos/orgs/clearworksai/agents/muse/state/resource-map"
+)
+
+INTERNAL_LIST_KEYS = (
+    "client_audits",
+    "positioning_docs",
+    "research_docs",
+    "memory_refs",
+    "notebooks",
+    "live_search",
+)
+
+DISCOVERY_KEYS = (
+    "client_audits",
+    "positioning_docs",
+    "research_docs",
+    "memory_refs",
+)
+
+PREFIX_BY_CATEGORY = {
+    "client_audits": "aud",
+    "positioning_docs": "pos",
+    "research_docs": "res",
+    "memory_refs": "mem",
+    "notebooks": "nb",
+}
+
+_SLUG_RE = re.compile(r"[a-z0-9]+")
+_DATE_RE = re.compile(r"^\d{4}-\d{2}-\d{2}$")
+
+
+def state_dir() -> Path:
+    return Path(os.environ.get("RESOURCE_MAP_STATE_DIR", DEFAULT_STATE_DIR)).expanduser()
+
+
+def manifest_path(vertical: str) -> Path:
+    return state_dir() / f"{vertical}.json"
+
+
+def manifest_md_path(vertical: str) -> Path:
+    return state_dir() / f"{vertical}.md"
+
+
+def slugify(name: str) -> str:
+    slug = "-".join(_SLUG_RE.findall((name or "").lower())).strip("-")
+    if not slug:
+        raise ValueError("slugify() produced an empty slug")
+    return slug
+
+
+def utc_now_iso() -> str:
+    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
+
+
+def atomic_write_json(path: Path, data: dict[str, object]) -> None:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    tmp_path: Path | None = None
+    try:
+        with tempfile.NamedTemporaryFile(
+            "w",
+            dir=path.parent,
+            delete=False,
+            encoding="utf-8",
+        ) as handle:
+            tmp_path = Path(handle.name)
+            json.dump(data, handle, indent=2)
+            handle.write("\n")
+            handle.flush()
+            os.fsync(handle.fileno())
+        os.replace(tmp_path, path)
+        tmp_path = None
+    finally:
+        if tmp_path is not None and tmp_path.exists():
+            tmp_path.unlink()
+
+
+def atomic_write_text(path: Path, text: str) -> None:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    tmp_path: Path | None = None
+    try:
+        with tempfile.NamedTemporaryFile(
+            "w",
+            dir=path.parent,
+            delete=False,
+            encoding="utf-8",
+        ) as handle:
+            tmp_path = Path(handle.name)
+            handle.write(text)
+            handle.flush()
+            os.fsync(handle.fileno())
+        os.replace(tmp_path, path)
+        tmp_path = None
+    finally:
+        if tmp_path is not None and tmp_path.exists():
+            tmp_path.unlink()
+
+
+def new_manifest(vertical: str, display_name: str) -> dict[str, object]:
+    if vertical != slugify(vertical):
+        raise ValueError("vertical must already be a slug")
+    now = utc_now_iso()
+    return {
+        "schema_version": SCHEMA_VERSION,
+        "vertical": vertical,
+        "display_name": display_name,
+        "generated_at": now,
+        "updated_at": now,
+        "external": {
+            "registry_path": None,
+            "notebook_id": None,
+            "framework_doc": None,
+            "source_count": 0,
+            "registry_updated_at": None,
+            "freshness": {},
+        },
+        "internal": {
+            "client_audits": [],
+            "positioning_docs": [],
+            "research_docs": [],
+            "memory_refs": [],
+            "notebooks": [],
+            "live_search": [],
+            "tooling": {},
+        },
+        "gaps": [],
+    }
+
+
+def _is_number(value: object) -> bool:
+    return isinstance(value, (int, float)) and not isinstance(value, bool)
+
+
+def _ensure_id(entry: dict[str, object], category: str, existing_ids: set[str]) -> None:
+    if isinstance(entry.get("id"), str) and entry["id"]:
+        return
+    title = str(entry.get("title") or Path(str(entry.get("path") or "")).stem or category)
+    base_id = f"{PREFIX_BY_CATEGORY[category]}_{slugify(title)}"
+    candidate = base_id
+    suffix = 2
+    while candidate in existing_ids:
+        candidate = f"{base_id}-{suffix}"
+        suffix += 1
+    entry["id"] = candidate
+
+
+def _discovery_ids(manifest: dict[str, object]) -> set[str]:
+    internal = manifest.get("internal", {})
+    if not isinstance(internal, dict):
+        return set()
+    ids: set[str] = set()
+    for key in DISCOVERY_KEYS:
+        entries = internal.get(key, [])
+        if not isinstance(entries, list):
+            continue
+        for entry in entries:
+            if isinstance(entry, dict) and isinstance(entry.get("id"), str):
+                ids.add(entry["id"])
+    return ids
+
+
+def _validate_discovery_entry(
+    errors: list[str],
+    key: str,
+    index: int,
+    entry: object,
+    seen_ids: set[str],
+) -> None:
+    if not isinstance(entry, dict):
+        errors.append(f"{key}[{index}] must be an object")
+        return
+    required = ("id", "title", "path", "matched_terms", "score", "confirmed")
+    for field in required:
+        if field not in entry:
+            errors.append(f"{key}[{index}] missing {field}")
+    entry_id = entry.get("id")
+    if not isinstance(entry_id, str) or not entry_id:
+        errors.append(f"{key}[{index}] id must be non-empty")
+    elif entry_id in seen_ids:
+        errors.append(f"{key}[{index}] duplicate id: {entry_id}")
+    else:
+        seen_ids.add(entry_id)
+
+    if not isinstance(entry.get("title"), str) or not str(entry.get("title")).strip():
+        errors.append(f"{key}[{index}] title must be non-empty")
+    if not isinstance(entry.get("path"), str) or not str(entry.get("path")).strip():
+        errors.append(f"{key}[{index}] path must be non-empty")
+    matched_terms = entry.get("matched_terms")
+    if not isinstance(matched_terms, list) or any(not isinstance(term, str) for term in matched_terms):
+        errors.append(f"{key}[{index}] matched_terms must be a list of strings")
+    if not _is_number(entry.get("score")):
+        errors.append(f"{key}[{index}] score must be numeric")
+    if not isinstance(entry.get("confirmed"), bool):
+        errors.append(f"{key}[{index}] confirmed must be a bool")
+    elif entry.get("confirmed") is not True:
+        errors.append(f"{key}[{index}] unconfirmed entry may not be persisted")
+
+    if key == "positioning_docs":
+        version = entry.get("version")
+        if version is not None and not isinstance(version, int):
+            errors.append(f"{key}[{index}] version must be an int or null")
+        latest = entry.get("latest")
+        if latest is not None and not isinstance(latest, bool):
+            errors.append(f"{key}[{index}] latest must be a bool when present")
+
+
+def validate_manifest(manifest: object) -> list[str]:
+    errors: list[str] = []
+    if not isinstance(manifest, dict):
+        return ["manifest must be an object"]
+
+    if manifest.get("schema_version") != SCHEMA_VERSION:
+        errors.append("schema_version must equal 1")
+
+    vertical = manifest.get("vertical")
+    if not isinstance(vertical, str) or not vertical:
+        errors.append("vertical must be a non-empty slug")
+    else:
+        try:
+            expected = slugify(vertical)
+        except ValueError:
+            errors.append("vertical must be a non-empty slug")
+        else:
+            if vertical != expected:
+                errors.append("vertical must be a normalized slug")
+
+    display_name = manifest.get("display_name")
+    if not isinstance(display_name, str) or not display_name.strip():
+        errors.append("display_name must be non-empty")
+
+    external = manifest.get("external")
+    if not isinstance(external, dict):
+        errors.append("external must be an object")
+        external = {}
+    if external.get("registry_path") is not None and (
+        not isinstance(external.get("registry_path"), str)
+        or not str(external.get("registry_path")).strip()
+    ):
+        errors.append("external.registry_path must be null or a non-empty string")
+    if not isinstance(external.get("freshness", {}), dict):
+        errors.append("external.freshness must be an object")
+
+    internal = manifest.get("internal")
+    if not isinstance(internal, dict):
+        errors.append("internal must be an object")
+        internal = {}
+    expected_keys = set(INTERNAL_LIST_KEYS) | {"tooling"}
+    for key in internal.keys():
+        if key not in expected_keys:
+            errors.append(f"internal has unknown key: {key}")
+    for key in INTERNAL_LIST_KEYS:
+        value = internal.get(key)
+        if not isinstance(value, list):
+            errors.append(f"internal.{key} must be a list")
+    tooling = internal.get("tooling")
+    if not isinstance(tooling, dict):
+        errors.append("internal.tooling must be an object")
+
+    seen_ids: set[str] = set()
+    for key in DISCOVERY_KEYS:
+        entries = internal.get(key, [])
+        if not isinstance(entries, list):
+            continue
+        for index, entry in enumerate(entries):
+            _validate_discovery_entry(errors, key, index, entry, seen_ids)
+
+    positioning_entries = internal.get("positioning_docs", [])
+    if isinstance(positioning_entries, list):
+        latest_count = 0
+        for entry in positioning_entries:
+            if isinstance(entry, dict) and entry.get("latest") is True:
+                latest_count += 1
+        if latest_count > 1:
+            errors.append("positioning_docs may contain at most one latest entry")
+
+    notebooks = internal.get("notebooks", [])
+    if isinstance(notebooks, list):
+        for index, entry in enumerate(notebooks):
+            if not isinstance(entry, dict):
+                errors.append(f"notebooks[{index}] must be an object")
+                continue
+            required = ("id", "title", "notebook_id", "url", "confirmed")
+            for field in required:
+                if field not in entry:
+                    errors.append(f"notebooks[{index}] missing {field}")
+            if not isinstance(entry.get("notebook_id"), str) or not str(entry.get("notebook_id")).strip():
+                errors.append(f"notebooks[{index}] notebook_id must be non-empty")
+            if not isinstance(entry.get("url"), str) or not str(entry.get("url")).strip():
+                errors.append(f"notebooks[{index}] url must be non-empty")
+            if entry.get("confirmed") is not True:
+                errors.append(f"notebooks[{index}] confirmed must be true")
+
+    live_search = internal.get("live_search", [])
+    if isinstance(live_search, list):
+        for index, entry in enumerate(live_search):
+            if not isinstance(entry, dict):
+                errors.append(f"live_search[{index}] must be an object")
+                continue
+            if not isinstance(entry.get("query"), str) or not str(entry.get("query")).strip():
+                errors.append(f"live_search[{index}] query must be non-empty")
+            if not isinstance(entry.get("returned_signal"), bool):
+                errors.append(f"live_search[{index}] returned_signal must be a bool")
+            date = entry.get("date")
+            if not isinstance(date, str) or not _DATE_RE.match(date):
+                errors.append(f"live_search[{index}] date must match YYYY-MM-DD")
+            if not isinstance(entry.get("note"), str):
+                errors.append(f"live_search[{index}] note must be a string")
+
+    gaps = manifest.get("gaps")
+    if not isinstance(gaps, list) or any(not isinstance(item, str) for item in gaps):
+        errors.append("gaps must be a list of strings")
+
+    return errors
+
+
+def load_manifest(vertical: str) -> dict[str, object]:
+    path = manifest_path(vertical)
+    if not path.exists():
+        raise FileNotFoundError(f"manifest not found: {path}")
+    with path.open(encoding="utf-8") as handle:
+        manifest = json.load(handle)
+    errors = validate_manifest(manifest)
+    if errors:
+        raise ValueError(f"manifest invalid: {'; '.join(errors)}")
+    return manifest
+
+
+def mark_latest_positioning_docs(manifest: dict[str, object]) -> None:
+    internal = manifest.get("internal")
+    if not isinstance(internal, dict):
+        return
+    docs = internal.get("positioning_docs")
+    if not isinstance(docs, list):
+        return
+    best_index: int | None = None
+    best_version = -1
+    for index, entry in enumerate(docs):
+        if not isinstance(entry, dict):
+            continue
+        version = entry.get("version")
+        if isinstance(version, int) and version > best_version:
+            best_version = version
+            best_index = index
+    for index, entry in enumerate(docs):
+        if isinstance(entry, dict):
+            if best_index is None:
+                entry.pop("latest", None)
+            else:
+                entry["latest"] = index == best_index
+
+
+def save_manifest(manifest: dict[str, object]) -> Path:
+    errors = validate_manifest(manifest)
+    if errors:
+        raise ValueError(f"manifest invalid: {'; '.join(errors)}")
+    manifest["updated_at"] = utc_now_iso()
+    path = manifest_path(str(manifest["vertical"]))
+    atomic_write_json(path, manifest)
+    write_manifest_md(manifest)
+    return path
+
+
+def _fmt_terms(entry: dict[str, object]) -> str:
+    terms = entry.get("matched_terms", [])
+    if not isinstance(terms, list) or not terms:
+        return "none"
+    return ", ".join(str(term) for term in terms)
+
+
+def _render_entry_lines(entries: list[object], formatter) -> list[str]:
+    if not entries:
+        return ["_none_"]
+    lines: list[str] = []
+    for entry in entries:
+        if isinstance(entry, dict):
+            lines.append(formatter(entry))
+    return lines or ["_none_"]
+
+
+def _format_positioning_entry(entry: dict[str, object]) -> str:
+    latest = " · LATEST" if entry.get("latest") else ""
+    version = f" (v{entry.get('version')})" if entry.get("version") is not None else ""
+    return f"- **{entry['title']}**{latest}{version} — `{entry['path']}`"
+
+
+def write_manifest_md(manifest: dict[str, object]) -> Path:
+    vertical = str(manifest["vertical"])
+    external = manifest.get("external", {})
+    internal = manifest.get("internal", {})
+    if not isinstance(external, dict):
+        external = {}
+    if not isinstance(internal, dict):
+        internal = {}
+    freshness = external.get("freshness", {})
+    if not isinstance(freshness, dict):
+        freshness = {}
+
+    lines = [
+        f"# {manifest['display_name']} Resource Map",
+        "",
+        f"Generated {manifest['generated_at']} · updated {manifest['updated_at']} · schema v{manifest['schema_version']}",
+        "",
+        "## External (research-pulse — by reference)",
+        f"- Registry: `{external.get('registry_path')}`" if external.get("registry_path") else "- Registry: _none_",
+    ]
+
+    notebook_id = external.get("notebook_id")
+    if isinstance(notebook_id, str) and notebook_id:
+        lines.append(
+            f"- Notebook: `{notebook_id}` — https://notebooklm.google.com/notebook/{notebook_id}"
+        )
+    else:
+        lines.append("- Notebook: _none_")
+    framework_doc = external.get("framework_doc")
+    lines.append(
+        f"- Framework doc: `{framework_doc}`" if isinstance(framework_doc, str) and framework_doc else "- Framework doc: _none_"
+    )
+    lines.append(f"- Sources (registry): {external.get('source_count', 0)}")
+    if freshness:
+        stale = freshness.get("is_stale") is True
+        age_hours = freshness.get("age_hours")
+        threshold = freshness.get("stale_threshold_hours")
+        age_text = f"{age_hours}h" if age_hours is not None else "unknown"
+        threshold_text = f"{threshold}h" if threshold is not None else "unknown"
+        lines.append(
+            f"- Freshness: {'STALE' if stale else 'fresh'} — age {age_text} (threshold {threshold_text})"
+        )
+        if stale and freshness.get("delta_refresh_command"):
+            lines.append(
+                f"  - Refresh: `{freshness['delta_refresh_command']}` (cron `{freshness.get('delta_cron_name')}`)"
+            )
+    else:
+        lines.append("- Freshness: unchecked")
+
+    headings = [
+        ("Client Audits", "client_audits", lambda entry: f"- **{entry['title']}** — `{entry['path']}` (score {entry['score']}, terms: {_fmt_terms(entry)})"),
+        ("Positioning Docs", "positioning_docs", _format_positioning_entry),
+        ("Research Docs", "research_docs", lambda entry: f"- **{entry['title']}** — `{entry['path']}` (score {entry['score']}, terms: {_fmt_terms(entry)})"),
+        ("Memory Refs", "memory_refs", lambda entry: f"- **{entry['title']}** — `{entry['path']}` (score {entry['score']}, terms: {_fmt_terms(entry)})"),
+        ("Notebooks", "notebooks", lambda entry: f"- **{entry['title']}** — `{entry['notebook_id']}` {entry['url']}"),
+        ("Live Search Patterns", "live_search", lambda entry: f"- `{entry['query']}` — {'signal' if entry['returned_signal'] else 'no signal'} ({entry['date']}) {entry['note']}"),
+    ]
+
+    for heading, key, formatter in headings:
+        lines.extend(["", f"## {heading}"])
+        entries = internal.get(key, [])
+        if not isinstance(entries, list):
+            entries = []
+        lines.extend(_render_entry_lines(entries, formatter))
+
+    lines.extend(["", "## Tooling"])
+    tooling = internal.get("tooling", {})
+    if isinstance(tooling, dict) and tooling:
+        for key in sorted(tooling):
+            lines.append(f"- {key}: `{tooling[key]}`")
+    else:
+        lines.append("_none_")
+
+    lines.extend(["", "## Gaps"])
+    gaps = manifest.get("gaps", [])
+    if isinstance(gaps, list) and gaps:
+        for gap in gaps:
+            lines.append(f"- {gap}")
+    else:
+        lines.append("_none_")
+
+    output = "\n".join(lines) + "\n"
+    path = manifest_md_path(vertical)
+    atomic_write_text(path, output)
+    return path
+
+
+def add_internal_entry(manifest: dict[str, object], category: str, entry: dict[str, object]) -> dict[str, object]:
+    if category not in DISCOVERY_KEYS:
+        raise ValueError(f"unsupported category: {category}")
+    if entry.get("confirmed") is not True:
+        raise ValueError("discovery entries must be confirmed before they are persisted")
+    internal = manifest.setdefault("internal", {})
+    if not isinstance(internal, dict):
+        raise ValueError("manifest internal block must be an object")
+    entries = internal.setdefault(category, [])
+    if not isinstance(entries, list):
+        raise ValueError(f"manifest internal.{category} must be a list")
+
+    existing_ids = _discovery_ids(manifest)
+    _ensure_id(entry, category, existing_ids)
+    entries.append(entry)
+    if category == "positioning_docs":
+        mark_latest_positioning_docs(manifest)
+    return entry
+
+
+def set_external(
+    manifest: dict[str, object],
+    *,
+    registry_path: str | None,
+    notebook_id: str | None,
+    framework_doc: str | None,
+    source_count: int,
+    registry_updated_at: str | None,
+) -> None:
+    external = manifest.setdefault("external", {})
+    if not isinstance(external, dict):
+        raise ValueError("manifest external block must be an object")
+    external["registry_path"] = registry_path
+    external["notebook_id"] = notebook_id
+    external["framework_doc"] = framework_doc
+    external["source_count"] = source_count
+    external["registry_updated_at"] = registry_updated_at
+
+
+def add_notebook(
+    manifest: dict[str, object],
+    *,
+    title: str,
+    notebook_id: str,
+    url: str,
+    confirmed: bool,
+    entry_id: str | None = None,
+) -> dict[str, object]:
+    if confirmed is not True:
+        raise ValueError("notebooks must be confirmed before they are persisted")
+    internal = manifest.setdefault("internal", {})
+    if not isinstance(internal, dict):
+        raise ValueError("manifest internal block must be an object")
+    notebooks = internal.setdefault("notebooks", [])
+    if not isinstance(notebooks, list):
+        raise ValueError("manifest internal.notebooks must be a list")
+    notebook = {
+        "id": entry_id or f"{PREFIX_BY_CATEGORY['notebooks']}_{slugify(title)}",
+        "title": title,
+        "notebook_id": notebook_id,
+        "url": url,
+        "confirmed": True,
+    }
+    notebooks.append(notebook)
+    return notebook
+
+
+def add_live_search(
+    manifest: dict[str, object],
+    *,
+    query: str,
+    returned_signal: bool,
+    date: str,
+    note: str,
+) -> dict[str, object]:
+    internal = manifest.setdefault("internal", {})
+    if not isinstance(internal, dict):
+        raise ValueError("manifest internal block must be an object")
+    live_search = internal.setdefault("live_search", [])
+    if not isinstance(live_search, list):
+        raise ValueError("manifest internal.live_search must be a list")
+    entry = {
+        "query": query,
+        "returned_signal": returned_signal,
+        "date": date,
+        "note": note,
+    }
+    live_search.append(entry)
+    return entry
+
+
+def set_tooling(manifest: dict[str, object], tooling: dict[str, object]) -> None:
+    internal = manifest.setdefault("internal", {})
+    if not isinstance(internal, dict):
+        raise ValueError("manifest internal block must be an object")
+    internal["tooling"] = dict(tooling)
+
+
+def compute_gaps(manifest: dict[str, object]) -> list[str]:
+    internal = manifest.get("internal", {})
+    if not isinstance(internal, dict):
+        raise ValueError("manifest internal block must be an object")
+    gaps: list[str] = []
+    for category in (*DISCOVERY_KEYS, "notebooks", "live_search"):
+        entries = internal.get(category, [])
+        if isinstance(entries, list) and not entries:
+            gaps.append(f"no confirmed {category}")
+    external = manifest.get("external", {})
+    if isinstance(external, dict) and external.get("freshness") == {}:
+        gaps.append("external freshness not checked")
+    manifest["gaps"] = gaps
+    return gaps
+
+
+def main(argv: list[str] | None = None) -> int:
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--init", action="store_true")
+    parser.add_argument("--vertical", required=True)
+    parser.add_argument("--display-name", required=True)
+    args = parser.parse_args(argv)
+
+    if not args.init:
+        print("only --init is supported", file=os.sys.stderr)
+        return 1
+
+    try:
+        manifest = new_manifest(args.vertical, args.display_name)
+        path = save_manifest(manifest)
+    except Exception as exc:  # pragma: no cover - CLI guard
+        print(str(exc), file=os.sys.stderr)
+        return 1
+
+    print(path)
+    return 0
+
+
+if __name__ == "__main__":  # pragma: no cover - CLI entrypoint
+    raise SystemExit(main())
