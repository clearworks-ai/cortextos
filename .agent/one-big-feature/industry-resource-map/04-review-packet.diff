+from __future__ import annotations
+
+import os
+import sys
+import tempfile
+import unittest
+import unittest.mock
+from pathlib import Path
+
+
+ROOT = Path(__file__).resolve().parent.parent
+if str(ROOT) not in sys.path:
+    sys.path.insert(0, str(ROOT))
+
+from scripts import resource_map as MODULE
+
+
+class ResourceMapTests(unittest.TestCase):
+    def make_entry(
+        self,
+        title: str,
+        path: str,
+        *,
+        score: int = 5,
+        matched_terms: list[str] | None = None,
+        version: int | None = None,
+    ) -> dict[str, object]:
+        entry: dict[str, object] = {
+            "title": title,
+            "path": path,
+            "matched_terms": matched_terms or ["aec"],
+            "score": score,
+            "confirmed": True,
+        }
+        if version is not None:
+            entry["version"] = version
+        return entry
+
+    def test_new_manifest_schema_valid(self) -> None:
+        manifest = MODULE.new_manifest("aec", "AEC")
+        self.assertEqual(MODULE.validate_manifest(manifest), [])
+        self.assertEqual(manifest["internal"]["tooling"], {})
+        self.assertEqual(manifest["internal"]["client_audits"], [])
+        self.assertEqual(manifest["generated_at"], manifest["updated_at"])
+
+    def test_validate_rejects_bad_schema_version(self) -> None:
+        manifest = MODULE.new_manifest("aec", "AEC")
+        manifest["schema_version"] = 2
+        self.assertTrue(any("schema_version" in error for error in MODULE.validate_manifest(manifest)))
+
+    def test_validate_rejects_non_slug_vertical(self) -> None:
+        manifest = MODULE.new_manifest("aec", "AEC")
+        manifest["vertical"] = "AEC"
+        self.assertTrue(any("normalized slug" in error for error in MODULE.validate_manifest(manifest)))
+
+    def test_validate_rejects_unknown_internal_key(self) -> None:
+        manifest = MODULE.new_manifest("aec", "AEC")
+        manifest["internal"]["mystery"] = []
+        self.assertTrue(any("unknown key" in error for error in MODULE.validate_manifest(manifest)))
+
+    def test_validate_rejects_unconfirmed_entry(self) -> None:
+        manifest = MODULE.new_manifest("aec", "AEC")
+        manifest["internal"]["client_audits"].append({
+            "id": "aud_bad",
+            "title": "Bad",
+            "path": "/tmp/bad.md",
+            "matched_terms": ["aec"],
+            "score": 5,
+            "confirmed": False,
+        })
+        errors = MODULE.validate_manifest(manifest)
+        self.assertTrue(any("unconfirmed entry may not be persisted" in error for error in errors), errors)
+        with tempfile.TemporaryDirectory() as tmp:
+            with unittest.mock.patch.dict(os.environ, {"RESOURCE_MAP_STATE_DIR": tmp}, clear=False):
+                with self.assertRaises(ValueError):
+                    MODULE.save_manifest(manifest)
+
+    def test_add_internal_entry_refuses_unconfirmed(self) -> None:
+        manifest = MODULE.new_manifest("aec", "AEC")
+        with self.assertRaises(ValueError):
+            MODULE.add_internal_entry(
+                manifest,
+                "client_audits",
+                {
+                    "title": "Bad",
+                    "path": "/tmp/bad.md",
+                    "matched_terms": ["aec"],
+                    "score": 2,
+                    "confirmed": False,
+                },
+            )
+
+    def test_add_internal_entry_id_collision_suffix(self) -> None:
+        manifest = MODULE.new_manifest("aec", "AEC")
+        one = MODULE.add_internal_entry(
+            manifest,
+            "client_audits",
+            self.make_entry("AEC Audit", "/tmp/audit-1.md"),
+        )
+        two = MODULE.add_internal_entry(
+            manifest,
+            "client_audits",
+            self.make_entry("AEC Audit", "/tmp/audit-2.md"),
+        )
+        self.assertEqual(one["id"], "aud_aec-audit")
+        self.assertEqual(two["id"], "aud_aec-audit-2")
+
+    def test_save_load_roundtrip(self) -> None:
+        with tempfile.TemporaryDirectory() as tmp:
+            with unittest.mock.patch.dict(os.environ, {"RESOURCE_MAP_STATE_DIR": tmp}, clear=False):
+                manifest = MODULE.new_manifest("aec", "AEC")
+                path = MODULE.save_manifest(manifest)
+                loaded = MODULE.load_manifest("aec")
+                self.assertEqual(path, MODULE.manifest_path("aec"))
+                self.assertEqual(loaded, manifest)
+                leftovers = sorted(p.name for p in Path(tmp).iterdir())
+                self.assertEqual(leftovers, ["aec.json", "aec.md"])
+
+    def test_md_twin_rendered(self) -> None:
+        with tempfile.TemporaryDirectory() as tmp:
+            with unittest.mock.patch.dict(os.environ, {"RESOURCE_MAP_STATE_DIR": tmp}, clear=False):
+                manifest = MODULE.new_manifest("aec", "AEC")
+                MODULE.set_external(
+                    manifest,
+                    registry_path="/tmp/pulse/aec.json",
+                    notebook_id="nb-123",
+                    framework_doc="/tmp/framework.md",
+                    source_count=14,
+                    registry_updated_at="2026-07-18T13:15:24Z",
+                )
+                manifest["external"]["freshness"] = {
+                    "is_stale": False,
+                    "age_hours": 1.2,
+                    "stale_threshold_hours": 18.0,
+                }
+                MODULE.add_notebook(
+                    manifest,
+                    title="Research Pulse: AEC",
+                    notebook_id="nb-123",
+                    url="https://notebooklm.google.com/notebook/nb-123",
+                    confirmed=True,
+                )
+                MODULE.compute_gaps(manifest)
+                MODULE.save_manifest(manifest)
+                md_path = MODULE.manifest_md_path("aec")
+                text = md_path.read_text(encoding="utf-8")
+                self.assertIn("## Client Audits", text)
+                self.assertIn("## Gaps", text)
+                self.assertIn("https://notebooklm.google.com/notebook/nb-123", text)
+                self.assertIn("Freshness: fresh", text)
+                self.assertIn("_none_", text)
+
+    def test_positioning_latest_highest_version(self) -> None:
+        manifest = MODULE.new_manifest("aec", "AEC")
+        MODULE.add_internal_entry(
+            manifest,
