+import { describe, it, expect, beforeEach, afterEach, beforeAll, afterAll } from 'vitest';
+import supertest from 'supertest';
+import { eq } from 'drizzle-orm';
+import { startTestServer, closeTestServer } from './helpers/testServer';
+import { loadTestModules } from './helpers/testDb';
+
+let serverContext: Awaited<ReturnType<typeof startTestServer>>;
+let testOrgId: string;
+let testUserId: string;
+
+beforeAll(async () => {
+  const loadedModules = await loadTestModules();
+  serverContext = await startTestServer();
+  const { request, agent } = serverContext;
+  
+  // Create a test org
+  const org = await loadedModules.db.insert(loadedModules.schema.organizations).values({
+    name: 'Test Org',
+    shortCode: 'TEST',
+    status: 'active',
+  }).returning();
+  testOrgId = org[0].id;
+  
+  // Create a test user
+  const user = await loadedModules.db.insert(loadedModules.schema.users).values({
+    username: 'testuser',
+    email: 'test@example.com',
+    password: await loadedModules.hashPassword('test-password-123'),
+    displayName: 'Test User',
+    role: 'owner',
+    orgId: testOrgId,
+  }).returning();
+  testUserId = user[0].id;
+  
+  // Login
+  await agent.post('/api/auth/login').send({
+    username: 'testuser',
+    password: 'test-password-123',
+  });
+}, 30000);
+
+afterAll(async () => {
+  if (serverContext) {
+    await closeTestServer(serverContext.httpServer);
+  }
+}, 30000);
+
+async function getTestServer() {
+  const loadedModules = await loadTestModules();
+  return { 
+    db: loadedModules.db, 
+    testServer: serverContext.agent, // Use authenticated agent
+    schema: loadedModules.schema,
+    orgId: testOrgId
+  };
+}
+
+describe('GET /api/meetings/:id - detail endpoint shape', () => {
+  beforeEach(async () => {
+    const { db, schema, orgId: testOrgId } = await getTestServer();
+    // Clean up test data
+    await db.delete(schema.meetingComments).where(eq(schema.meetingComments.orgId, testOrgId));
+    await db.delete(schema.meetingApprovals).where(eq(schema.meetingApprovals.orgId, testOrgId));
+    await db.delete(schema.meetingContacts).where(eq(schema.meetingContacts.meetingId, -1)); // Will delete nothing but safe
+    await db.delete(schema.meetings).where(eq(schema.meetings.orgId, testOrgId));
+  });
+
+  it('returns comments and approvals arrays alongside meeting and contacts', async () => {
+    const { db, testServer, schema, orgId: testOrgId } = await getTestServer();
+    
+    // Create a meeting
+    const meeting = await db.insert(schema.meetings).values({
+      orgId: testOrgId,
+      title: 'Test Meeting',
+      approvalStatus: 'draft',
+    }).returning();
+    const meetingId = meeting[0].id;
+
+    // Add a contact
+    await db.insert(schema.meetingContacts).values({
+      meetingId,
+      name: 'John Doe',
+      email: 'john@example.com',
+      role: 'Attendee',
+      attendanceStatus: 'confirmed',
+    });
+
+    // Add a comment
+    await db.insert(schema.meetingComments).values({
+      orgId: testOrgId,
+      meetingId,
+      authorRole: 'owner',
+      body: 'Test comment',
+    });
+
+    // Add an approval
+    await db.insert(schema.meetingApprovals).values({
+      orgId: testOrgId,
+      meetingId,
+      role: 'owner',
+      signerName: 'Test Owner',
+      signatureText: 'Test signature',
+      signedAt: new Date(),
+    });
+
+    // Request the meeting detail
+    const res = await testServer
+      .get(`/api/meetings/${meetingId}?orgId=${testOrgId}`);
+
+    expect(res.status).toBe(200);
+    expect(res.body).toHaveProperty('meeting');
+    expect(res.body).toHaveProperty('contacts');
+    expect(res.body).toHaveProperty('comments');
+    expect(res.body).toHaveProperty('approvals');
+
+    // Verify array types
+    expect(Array.isArray(res.body.contacts)).toBe(true);
+    expect(Array.isArray(res.body.comments)).toBe(true);
+    expect(Array.isArray(res.body.approvals)).toBe(true);
+
+    // Verify the seeded data appears
+    expect(res.body.contacts.length).toBeGreaterThan(0);
+    expect(res.body.contacts[0]).toHaveProperty('name', 'John Doe');
+    
+    expect(res.body.comments.length).toBeGreaterThan(0);
+    expect(res.body.comments[0]).toHaveProperty('body', 'Test comment');
+    
+    expect(res.body.approvals.length).toBeGreaterThan(0);
+    expect(res.body.approvals[0]).toHaveProperty('role', 'owner');
+  });
+
+  it('returns empty comments and approvals arrays when none exist', async () => {
+    const { db, testServer, schema, orgId: testOrgId } = await getTestServer();
+    
+    // Create a meeting without comments or approvals
+    const meeting = await db.insert(schema.meetings).values({
+      orgId: testOrgId,
+      title: 'Empty Meeting',
+      approvalStatus: 'draft',
+    }).returning();
+    const meetingId = meeting[0].id;
+
+    // Request the meeting detail
+    const res = await testServer
+      .get(`/api/meetings/${meetingId}?orgId=${testOrgId}`);
+
+    expect(res.status).toBe(200);
+    expect(res.body).toHaveProperty('comments');
+    expect(res.body).toHaveProperty('approvals');
+    expect(Array.isArray(res.body.comments)).toBe(true);
+    expect(Array.isArray(res.body.approvals)).toBe(true);
+    expect(res.body.comments.length).toBe(0);
+    expect(res.body.approvals.length).toBe(0);
+  });
+});
