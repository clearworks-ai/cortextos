#!/usr/bin/env bash
set -euo pipefail

SECRET_PATH="${PIPELINE_SECRET_PATH:-$HOME/.pipeline-secret}"
FORCE=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    --path)
      SECRET_PATH="$2"
      shift 2
      ;;
    --force|--rotate)
      FORCE=1
      shift
      ;;
    -h|--help)
      cat <<'EOF'
Usage: bin/pipeline-provision-secret [--path <secret-path>] [--force]

Creates a 32-byte hex signing secret for the hard-spec gate at the target path
and chmods it to 600. Refuses to overwrite an existing file unless --force is
provided.
EOF
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      exit 1
      ;;
  esac
done

if [ -e "$SECRET_PATH" ] && [ "$FORCE" -ne 1 ]; then
  echo "Refusing to overwrite existing secret at $SECRET_PATH (pass --force to rotate)." >&2
  exit 1
fi

mkdir -p "$(dirname "$SECRET_PATH")"
node -e 'process.stdout.write(require("crypto").randomBytes(32).toString("hex"))' > "$SECRET_PATH"
chmod 600 "$SECRET_PATH"
echo "Provisioned pipeline secret at $SECRET_PATH"
