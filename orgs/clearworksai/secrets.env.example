# cortextOS secrets for clearworksai — EXAMPLE (copy to secrets.env; secrets.env is gitignored)
#
# Canonical source of truth is 1Password vault "Openclaw". Values may be either:
#   1. op:// secret references (canonical) — resolved at env-load time by the shared
#      loader in src/utils/env.ts when OP_SERVICE_ACCOUNT_TOKEN is available.
#   2. Literal values (fallback) — used as-is; required on machines without a token
#      (offline / CI). If an op:// ref is present with no token, the literal op://
#      string passes through unresolved and one warning is logged; run
#      `cortextos doctor` to surface this.
#
# OP_SERVICE_ACCOUNT_TOKEN itself MUST be a literal (it cannot resolve itself).
OP_SERVICE_ACCOUNT_TOKEN=

BOT_TOKEN=op://Openclaw/Telegram Claude Code/credential
CHAT_ID=op://Openclaw/Telegram Claude Code/chat_id
ACTIVITY_CHAT_ID=

CLEARPATH_BASE_URL=
CLEARPATH_API_KEY=
CLEARPATH_ORG_ID=
CLEARPATH_USER_ID=

TODOIST_TOKEN=op://Openclaw/Todoist API Credentials/credential
GEMINI_API_KEY=op://Openclaw/Google AI Studio API Key Openclaw/credential

MOXIE_API_KEY=
MOXIE_BASE_URL=
TELEGRAPH_ACCESS_TOKEN=
